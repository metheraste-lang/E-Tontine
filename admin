<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Direction Générale — E-Tontine Tchad</title>
    <style>
        :root {
            --bg-main: #0b1329;
            --bg-card: #1c2541;
            --emerald: #10b981;
            --emerald-hover: #059669;
            --blue: #3b82f6;
            --rose: #f43f5e;
            --amber: #f59e0b;
            --text-main: #f1f5f9;
            --text-muted: #94a3b8;
            --border: #334155;
        }

        body { 
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; 
            background-color: var(--bg-main); 
            color: var(--text-main); 
            margin: 0; 
            padding: 0; 
        }

        nav { 
            background-color: rgba(28, 37, 65, 0.9); 
            backdrop-filter: blur(10px);
            padding: 0 25px; 
            height: 70px; 
            display: flex; 
            align-items: center; 
            justify-content: space-between; 
            border-bottom: 2px solid var(--amber);
            position: sticky;
            top: 0;
            z-index: 100;
        }
        .logo { font-weight: 900; font-size: 1.2rem; letter-spacing: -0.05em;}
        .logo span { color: var(--amber); }

        #notification-container {
            position: fixed;
            top: 85px;
            right: 20px;
            z-index: 2000;
            display: flex;
            flex-direction: column;
            gap: 10px;
            max-width: 350px;
            width: 100%;
        }
        .toast-notification {
            background: var(--bg-card);
            border-left: 4px solid var(--amber);
            color: var(--text-main);
            padding: 15px;
            border-radius: 8px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.4);
            border: 1px solid var(--border);
            font-size: 0.9rem;
            animation: slideIn 0.3s ease forwards;
        }
        @keyframes slideIn { from { transform: translateX(120%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }

        .container { max-width: 1200px; margin: 0 auto; padding: 20px; box-sizing: border-box; }
        
        .card { 
            background: var(--bg-card); 
            padding: 25px; 
            border-radius: 20px; 
            border: 1px solid var(--border); 
            margin-bottom: 25px;
            box-shadow: 0 10px 20px rgba(0,0,0,0.2);
        }

        .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 25px; }
        @media(max-width: 992px) { .stats-grid { grid-template-columns: repeat(2, 1fr); } }
        @media(max-width: 576px) { .stats-grid { grid-template-columns: 1fr; } }
        
        .stat-card { 
            background: linear-gradient(145deg, #1e293b, #0f172a); 
            padding: 20px; 
            border-radius: 16px; 
            border: 1px solid var(--border); 
        }
        .stat-card h4 { margin: 0; font-size: 0.8rem; text-transform: uppercase; color: var(--text-muted); letter-spacing: 0.05em; }
        .stat-card .value { font-size: 1.6rem; font-weight: 800; margin-top: 10px; color: white; }

        .tabs-menu { display: flex; background: var(--bg-card); border-radius: 12px; padding: 5px; margin: 20px 0; border: 1px solid var(--border); }
        .tab-link { flex: 1; text-align: center; padding: 12px; cursor: pointer; font-weight: 600; border-radius: 8px; color: var(--text-muted); transition: 0.3s; }
        .tab-link.active { background: var(--bg-main); color: var(--amber); border: 1px solid var(--border); }

        .tx-table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
        .tx-table th { padding: 14px; background: rgba(11, 19, 41, 0.6); color: var(--text-muted); font-weight: 600; text-align: left; }
        .tx-table td { padding: 14px; border-bottom: 1px solid var(--border); }
        
        .badge { padding: 5px 12px; border-radius: 20px; font-weight: bold; font-size: 0.75rem; background: rgba(245, 158, 11, 0.2); color: var(--amber); display: inline-block; }
        .badge.success { background: rgba(16, 185, 129, 0.2); color: var(--emerald); }
        .badge.danger { background: rgba(244, 63, 94, 0.2); color: var(--rose); }

        .form-group { margin-bottom: 18px; }
        .form-group label { display: block; font-size: 0.8rem; font-weight: 600; margin-bottom: 6px; color: var(--text-muted); text-transform: uppercase; }
        .form-group input { 
            width: 100%; padding: 14px; background: var(--bg-main); border: 1px solid var(--border); 
            border-radius: 10px; color: white; box-sizing: border-box; font-size: 1rem;
        }
        .form-group input:focus { border-color: var(--amber); outline: none; }

        .btn-block { width: 100%; padding: 14px; border-radius: 10px; font-weight: bold; cursor: pointer; color: white; border: none; background: linear-gradient(135deg, var(--amber), #d97706); }

        .btn-action { padding: 6px 12px; border-radius: 6px; font-weight: bold; border: none; cursor: pointer; font-size: 0.8rem; margin-right: 5px; color: white; transition: opacity 0.2s; }
        .btn-action:hover { opacity: 0.8; }
        .btn-approve { background: var(--emerald); }
        .btn-reject { background: var(--rose); }
        .btn-reset { background: var(--blue); }
        .btn-delete { background: var(--rose); }

        .hidden { display: none !important; }
        .proof-box { background: var(--bg-main); padding: 8px; border-radius: 6px; font-family: monospace; font-size: 0.8rem; max-width: 250px; overflow-wrap: break-word; color: #a7f3d0; border: 1px solid #1e293b; }
    </style>
</head>
<body>

    <div id="notification-container"></div>

    <!-- NAVIGATION ADMIN -->
    <nav>
        <div class="logo">👑 DIRECTION GÉNÉRALE — <span>E-TONTINE TCHAD</span></div>
        <div id="session-status" style="font-size: 0.85rem; color: var(--text-muted);">Session Admin : <b style="color:var(--rose);">Déconnectée</b></div>
    </nav>

    <!-- ÉCRAN DE CONNEXION ADMIN -->
    <div id="admin-login-screen" class="container" style="max-width: 450px; margin-top: 60px;">
        <div class="card">
            <h2 style="margin-top:0; text-align:center; font-size: 1.5rem; color: var(--amber);">Accès Direction Générale</h2>
            <form onsubmit="handleAdminLogin(event)">
                <div class="form-group">
                    <label>Adresse Email Admin</label>
                    <input type="email" id="admin-email" placeholder="admin@etontine.td" required>
                </div>
                <div class="form-group">
                    <label>Mot de passe secret</label>
                    <input type="password" id="admin-password" placeholder="••••••••" required>
                </div>
                <button type="submit" class="btn-block" style="margin-bottom: 15px;">S'authentifier au système</button>
                <button type="button" class="btn-block" style="background: transparent; border: 1px solid var(--border); color: var(--text-muted);" onclick="toggleLoginRegister(true)">Créer un sous-compte Admin</button>
            </form>
        </div>
    </div>

    <!-- ÉCRAN DE CRÉATION DE COMPTE ADMIN (CACHÉ PAR DÉFAUT) -->
    <div id="admin-register-screen" class="container hidden" style="max-width: 450px; margin-top: 60px;">
        <div class="card" style="border-color: var(--blue);">
            <h2 style="margin-top:0; text-align:center; font-size: 1.5rem; color: var(--blue);">Nouvel Administrateur</h2>
            <p style="color: var(--text-muted); font-size: 0.85rem; text-align: center; margin-bottom: 25px;">Le mot de passe doit comporter <b>exactement 8 chiffres</b>.</p>
            <form onsubmit="handleAdminRegister(event)">
                <div class="form-group">
                    <label>Adresse Email</label>
                    <input type="email" id="new-admin-email" placeholder="exemple@etontine.td" required>
                </div>
                <div class="form-group">
                    <label>Code Secret (8 Chiffres)</label>
                    <input type="password" id="new-admin-password" placeholder="Ex: 12345678" pattern="[0-9]{8}" maxlength="8" required>
                </div>
                <button type="submit" class="btn-block" style="background: linear-gradient(135deg, var(--blue), #2563eb); margin-bottom: 15px;">Enregistrer l'administrateur</button>
                <button type="button" class="btn-block" style="background: transparent; border: 1px solid var(--border); color: var(--text-muted);" onclick="toggleLoginRegister(false)">Retour à la connexion</button>
            </form>
        </div>
    </div>

    <!-- PANNEAU CENTRAL (CACHÉ TANT QUE PAS CONNECTÉ) -->
    <div id="admin-dashboard-panel" class="container hidden">
        
        <!-- STATS DE SURVEILLANCE -->
        <div class="stats-grid">
            <div class="stat-card" style="border-left: 4px solid var(--amber);">
                <h4>Flux en attente</h4>
                <div class="value" id="adm-stat-pending" style="color: var(--amber);">0</div>
            </div>
            <div class="stat-card" style="border-left: 4px solid var(--emerald);">
                <h4>Fonds Globaux Épargnés</h4>
                <div class="value" id="adm-stat-vault">0 FCFA</div>
            </div>
            <div class="stat-card" style="border-left: 4px solid var(--rose);">
                <h4>Total Commissions Système (9%)</h4>
                <div class="value" id="adm-stat-fees" style="color: var(--rose);">0 FCFA</div>
            </div>
            <div class="stat-card" style="border-left: 4px solid var(--blue);">
                <h4>Membres Enregistrés</h4>
                <div class="value" id="adm-stat-users" style="color: var(--blue);">0</div>
            </div>
        </div>

        <!-- ONGLETS DE NAVIGATION -->
        <div class="tabs-menu">
            <div class="tab-link active" id="tab-requests" onclick="switchAdminTab('requests')">⏳ Demandes Entrantes</div>
            <div class="tab-link" id="tab-users" onclick="switchAdminTab('users')">👥 Base de Données Membres</div>
            <div class="tab-link" id="tab-archive" onclick="switchAdminTab('archive')">🗄️ Historique des Validations</div>
        </div>

        <!-- SECTION 1 : ATTENTE DE VALIDATION -->
        <div id="admin-tab-requests" class="card">
            <h3 style="margin-top: 0; margin-bottom: 20px; color: var(--amber);">⚠️ Opérations en Attente d'Approbation</h3>
            <div style="overflow-x: auto;">
                <table class="tx-table">
                    <thead>
                        <tr>
                            <th>Date / Heure</th>
                            <th>Utilisateur</th>
                            <th>Type & Tontine Target</th>
                            <th>Infos Flux (Expéditeur/Frais)</th>
                            <th>Montant Brut</th>
                            <th>Vérification / Justificatif</th>
                            <th>Décision Directeur</th>
                        </tr>
                    </thead>
                    <tbody id="adm-pending-table-body"></tbody>
                </table>
            </div>
        </div>

        <!-- SECTION 2 : LES UTILISATEURS -->
        <div id="admin-tab-users" class="card hidden">
            <h3 style="margin-top: 0; margin-bottom: 20px; color: var(--blue);">📋 Utilisateurs Connectés au Système</h3>
            <div style="overflow-x: auto;">
                <table class="tx-table">
                    <thead>
                        <tr>
                            <th>ID Interne</th>
                            <th>Nom & Prénom Complet</th>
                            <th>Numéro de Téléphone</th>
                            <th>Action Sécurité</th>
                        </tr>
                    </thead>
                    <tbody id="adm-users-table-body"></tbody>
                </table>
            </div>
        </div>

        <!-- SECTION 3 : LES ARCHIVES FINANCIÈRES -->
        <div id="admin-tab-archive" class="card hidden">
            <h3 style="margin-top: 0; margin-bottom: 20px; color: var(--emerald);">🗄️ Historique Général des Flux Clôturés</h3>
            <div style="overflow-x: auto;">
                <table class="tx-table">
                    <thead>
                        <tr>
                            <th>Date & Heure</th>
                            <th>Utilisateur</th>
                            <th>Type</th>
                            <th>Tontine</th>
                            <th>Opérateur</th>
                            <th>Montant Brut</th>
                            <th>Statut Final</th>
                        </tr>
                    </thead>
                    <tbody id="adm-archive-table-body"></tbody>
                </table>
            </div>
        </div>

    </div>

    <script>
        // Initialisation de la base des administrateurs
        if (!localStorage.getItem('t_admins')) {
            localStorage.setItem('t_admins', JSON.stringify([]));
        }

        // Compte Super-Admin de secours non effaçable
        const MASTER_ADMIN = {
            email: "admin@etontine.td",
            password: "AdminEton@2026"
        };

        function loadData() {
            return {
                users: JSON.parse(localStorage.getItem('t_users')) || [],
                tontines: JSON.parse(localStorage.getItem('t_tontines')) || [],
                history: JSON.parse(localStorage.getItem('t_history')) || [],
                admins: JSON.parse(localStorage.getItem('t_admins')) || []
            };
        }

        function saveData(data) {
            localStorage.setItem('t_users', JSON.stringify(data.users));
            localStorage.setItem('t_tontines', JSON.stringify(data.tontines));
            localStorage.setItem('t_history', JSON.stringify(data.history));
            localStorage.setItem('t_admins', JSON.stringify(data.admins));
        }

        function showNotification(message) {
            const container = document.getElementById('notification-container');
            const toast = document.createElement('div');
            toast.className = 'toast-notification';
            toast.innerHTML = `⚙️ <b>Système:</b> ${message}`;
            container.appendChild(toast);
            setTimeout(() => { toast.remove(); }, 4000);
        }

        function toggleLoginRegister(showRegister) {
            if (showRegister) {
                document.getElementById('admin-login-screen').classList.add('hidden');
                document.getElementById('admin-register-screen').classList.remove('hidden');
            } else {
                document.getElementById('admin-register-screen').classList.add('hidden');
                document.getElementById('admin-login-screen').classList.remove('hidden');
            }
        }

        // FONCTION DE HASHAGE UNIQUE (Synchrone avec la page client)
        async function hashString(str) {
            const buffer = new TextEncoder().encode(str);
            const hash = await crypto.subtle.digest('SHA-256', buffer);
            return Array.from(new Uint8Array(hash)).map(b => b.toString(16).padStart(2, '0')).join('');
        }

        // INSCRIPTION D'UN NOUVEL ADMIN
        async function handleAdminRegister(e) {
            e.preventDefault();
            const email = document.getElementById('new-admin-email').value;
            const password = document.getElementById('new-admin-password').value;

            // Validation stricte regex pour s'assurer que ce ne sont que 8 chiffres
            const digitRegex = /^[0-9]{8}$/;
            if (!digitRegex.test(password)) {
                showNotification("❌ Erreur : Le mot de passe doit comporter précisément 8 chiffres.");
                return;
            }

            let data = loadData();
            
            if (email === MASTER_ADMIN.email || data.admins.find(a => a.email === email)) {
                showNotification("⚠️ Cette adresse email administrateur est déjà configurée.");
                return;
            }

            const securePasswordHash = await hashString(password);
            data.admins.push({ email, password: securePasswordHash });
            saveData(data);

            showNotification("🎉 Compte Admin créé ! Connectez-vous.");
            e.target.reset();
            toggleLoginRegister(false);
        }

        // CONNEXION ADMIN COMPOSITE (MASTER OU PERSISTÉ)
        async function handleAdminLogin(e) {
            e.preventDefault();
            const email = document.getElementById('admin-email').value;
            const password = document.getElementById('admin-password').value;

            let isAuthorized = false;
            let data = loadData();

            // Vérification 1 : Master Admin
            if (email === MASTER_ADMIN.email && password === MASTER_ADMIN.password) {
                isAuthorized = true;
            } else {
                // Vérification 2 : Comptes créés chiffrés
                const inputHash = await hashString(password);
                const foundAdmin = data.admins.find(a => a.email === email && a.password === inputHash);
                if (foundAdmin) isAuthorized = true;
            }

            if (isAuthorized) {
                document.getElementById('admin-login-screen').classList.add('hidden');
                document.getElementById('admin-dashboard-panel').classList.remove('hidden');
                document.getElementById('session-status').innerHTML = `Session Admin : <b style="color:var(--emerald);">En ligne</b>`;
                
                showNotification("Accès autorisé. Tableau de contrôle actif.");
                renderAdminDashboard();
            } else {
                showNotification("❌ Accès refusé. Identifiants invalides.");
            }
        }

        function switchAdminTab(tabId) {
            document.getElementById('admin-tab-requests').classList.add('hidden');
            document.getElementById('admin-tab-users').classList.add('hidden');
            document.getElementById('admin-tab-archive').classList.add('hidden');
            document.querySelectorAll('.tab-link').forEach(l => l.classList.remove('active'));
            
            document.getElementById('admin-tab-' + tabId).classList.remove('hidden');
            document.getElementById('tab-' + tabId).classList.add('active');
        }

        function renderAdminDashboard() {
            const data = loadData();

            let pendingCount = 0;
            let totalVault = 0;
            let totalFeesCollected = 0;

            data.history.forEach(tx => {
                if (tx.status === "En attente") pendingCount++;
                if (tx.status === "Succès") {
                    totalVault += tx.amount;
                    if (tx.type === "Retrait" && tx.feeApplied) {
                        totalFeesCollected += tx.feeApplied;
                    }
                }
            });

            document.getElementById('adm-stat-pending').innerText = pendingCount;
            document.getElementById('adm-stat-vault').innerText = totalVault.toLocaleString() + " FCFA";
            document.getElementById('adm-stat-fees').innerText = totalFeesCollected.toLocaleString() + " FCFA";
            document.getElementById('adm-stat-users').innerText = data.users.length;

            // 1. REQUÊTES EN ATTENTE
            const pendingTable = document.getElementById('adm-pending-table-body');
            pendingTable.innerHTML = '';

            const pendingItems = data.history.filter(h => h.status === 'En attente');
            if(pendingItems.length === 0) {
                pendingTable.innerHTML = `<tr><td colspan="7" style="text-align:center; color: var(--text-muted); padding:30px;">Aucune demande en attente.</td></tr>`;
            }

            pendingItems.forEach(tx => {
                const tr = document.createElement('tr');
                let flowDetails = "";
                let amountDisplay = "";

                if (tx.type === "Dépôt") {
                    flowDetails = `📱 Expéditeur: <b style="color:white;">${tx.userDepositPhone || 'Non spécifié'}</b><br><small style="color:var(--text-muted);">Via ${tx.operator}</small>`;
                    amountDisplay = `<b style="color: var(--emerald); font-size:1.1rem;">+${tx.amount.toLocaleString()} F</b>`;
                } else {
                    const brutAbs = Math.abs(tx.amount);
                    const systemFee = Math.round(brutAbs * 0.09);
                    const netToTransfer = brutAbs - systemFee;
                    
                    flowDetails = `
                        <span style="color:var(--rose);">Frais (9%): -${systemFee.toLocaleString()} F</span><br>
                        💸 Net à envoyer: <b style="color:var(--emerald);">${netToTransfer.toLocaleString()} F</b>
                    `;
                    amountDisplay = `<b style="color: var(--rose); font-size:1.1rem;">${tx.amount.toLocaleString()} F</b>`;
                }

                tr.innerHTML = `
                    <td>${tx.date}</td>
                    <td><b>${tx.userName}</b><br><small style="color:var(--text-muted);">UID: ${tx.userId}</small></td>
                    <td><span class="badge">${tx.type}</span><br><small style="color:white;">${tx.tontineName}</small></td>
                    <td>${flowDetails}</td>
                    <td>${amountDisplay}</td>
                    <td><div class="proof-box">${tx.proof}</div></td>
                    <td>
                        <button class="btn-action btn-approve" onclick="processTransaction(${tx.id}, 'Succès')">Accorder</button>
                        <button class="btn-action btn-reject" onclick="processTransaction(${tx.id}, 'Refusé')">Refuser</button>
                    </td>
                `;
                pendingTable.appendChild(tr);
            });

            // 2. UTILISATEURS
            const usersTable = document.getElementById('adm-users-table-body');
            usersTable.innerHTML = '';
            
            if(data.users.length === 0) {
                usersTable.innerHTML = `<tr><td colspan="4" style="text-align:center; color: var(--text-muted); padding:20px;">Aucun utilisateur inscrit.</td></tr>`;
            }

            data.users.forEach(u => {
                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td style="font-family:monospace; color:var(--amber);">${u.id}</td>
                    <td><b>${u.name}</b></td>
                    <td>📞 ${u.phone}</td>
                    <td>
                        <button class="btn-action btn-reset" onclick="resetUserPassword('${u.id}', '${u.name}')">Reset Passe</button>
                        <button class="btn-action btn-delete" onclick="deleteUser('${u.id}', '${u.name}')">Supprimer</button>
                    </td>
                `;
                usersTable.appendChild(tr);
            });

            // 3. ARCHIVES
            const archiveTable = document.getElementById('adm-archive-table-body');
            archiveTable.innerHTML = '';
            data.history.filter(h => h.status !== 'En attente').forEach(tx => {
                const tr = document.createElement('tr');
                let badgeClass = tx.status === 'Succès' ? 'success' : 'danger';
                tr.innerHTML = `
                    <td>${tx.date}</td>
                    <td>${tx.userName}</td>
                    <td><b>${tx.type}</b></td>
                    <td>${tx.tontineName}</td>
                    <td>${tx.operator || 'Système'}</td>
                    <td style="color:${tx.amount < 0 ? 'var(--rose)':'var(--emerald)'}; font-weight:bold;">${tx.amount.toLocaleString()} F</td>
                    <td><span class="badge ${badgeClass}">${tx.status}</span></td>
                `;
                archiveTable.appendChild(tr);
            });
        }

        function processTransaction(txId, newStatus) {
            let data = loadData();
            let tx = data.history.find(h => h.id === txId);
            if (tx) {
                tx.status = newStatus;
                if (tx.type === "Retrait" && newStatus === "Succès") {
                    const brutAbs = Math.abs(tx.amount);
                    tx.feeApplied = Math.round(brutAbs * 0.09);
                }
                saveData(data);
                showNotification(`Transaction réglée sur [${newStatus}].`);
                renderAdminDashboard();
            }
        }

        async function resetUserPassword(userId, userName) {
            const newPassword = prompt(`Entrez le nouveau mot de passe pour ${userName} :`, "123456");
            if (newPassword === null) return;

            if (newPassword.length < 6) {
                alert("Le mot de passe doit contenir au moins 6 caractères.");
                return;
            }

            let data = loadData();
            let user = data.users.find(u => u.id === userId);

            if (user) {
                user.password = await hashString(newPassword);
                saveData(data);
                showNotification(`🔑 Mot de passe de ${userName} réinitialisé avec succès.`);
                renderAdminDashboard();
            }
        }

        function deleteUser(userId, userName) {
            if (confirm(`⚠️ Voulez-vous vraiment supprimer définitivement ${userName} ?`)) {
                let data = loadData();
                data.users = data.users.filter(u => u.id !== userId);
                saveData(data);
                showNotification(`❌ L'utilisateur ${userName} a été supprimé.`);
                renderAdminDashboard();
            }
        }
    </script>
</body>
</html>
